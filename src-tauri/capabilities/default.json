{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl-schema.json",
  "identifier": "default",
  "description": "Default capability set for Odyssey Chronicle",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "dialog:default"
  ]
}
